# Copy to .env only when configuring manually.
# The recommended path is:
#   docker compose -f installer.compose.yaml up -d --build
#   docker compose -f installer.compose.yaml logs veiron-installer
# Then open http://SERVER_IP:8080 with the one-time setup token.

COMPOSE_PROJECT_NAME=veiron-control-plane
STACK_VERSION=1.0.0
TZ=Europe/Bucharest

# Deployment source: build | ghcr
DEPLOYMENT_SOURCE=build
VEIRON_VERSION=latest
VEIRON_RUNTIME_IMAGE=ghcr.io/andreidohot/veiron-runtime
VEIRON_OPS_IMAGE=ghcr.io/andreidohot/veiron-ops
VEIRON_BACKUP_IMAGE=ghcr.io/andreidohot/veiron-backup

# Identity
BASE_DOMAIN=example.com
NODE_NAME=bootstrap-eu-1
ADMIN_EMAIL=operator@example.com
ADMIN_USER=veiron-admin

# Role: standalone | controller | agent
CONTROL_ROLE=controller
CONTROLLER_URL=
ENROLLMENT_TOKEN=
RELEASE_BUNDLE_URL=

# Public endpoints. Defaults are derived from BASE_DOMAIN by the web installer.
CONTROL_HOST=control.example.com
RPC_HOST=rpc.example.com
FLEET_HOST=fleet.example.com
GRAFANA_HOST=grafana.example.com
PROMETHEUS_HOST=prometheus.example.com
POOL_HOST=pool.example.com
P2P_HOST=node.example.com

# Public ports
HTTP_PORT=80
HTTPS_PORT=443
P2P_PORT=20787
SEED_NODES_TOML=
OPS_BOOTSTRAP_PORT=8080

# Cloudflare: disabled | dns | tunnel
CLOUDFLARE_MODE=disabled
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_NAME=veiron-control-plane
PUBLIC_IPV4=
CLOUDFLARE_PROXY_HTTP=true

# Optional pool profile
ENABLE_POOL=false
POOL_NAME=Veiron Reference Pool
POOL_ADDRESS=

# Indexer refresh loop
INDEXER_INTERVAL_SECONDS=15

# PostgreSQL reserved for control-plane metadata and the PostgreSQL-backed
# indexer migration. Current chain consensus state remains native filesystem data.
POSTGRES_DB=veiron
POSTGRES_USER=veiron

# Monitoring and retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION_HOURS=720
GRAFANA_ADMIN_USER=admin
ALERT_DISCORD_ENABLED=false
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_FROM=
ALERT_SMTP_TO=
ALERT_SMTP_USERNAME=
ALERT_SMTP_STARTTLS=true

# Backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
CHAIN_SNAPSHOT_ENABLED=true
CHAIN_SNAPSHOT_STOP_SERVICES=true
BACKUP_REMOTE_ENABLED=false
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_REGION=auto

# Resource limits (Compose accepts values such as 512M, 2G)
NODE_MEMORY_LIMIT=3G
RPC_MEMORY_LIMIT=3G
CONTROL_MEMORY_LIMIT=1G
INDEXER_MEMORY_LIMIT=1G
POSTGRES_MEMORY_LIMIT=1G
