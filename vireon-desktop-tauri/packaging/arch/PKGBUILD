# Maintainer: Veiron Network <admin@veiron.network>
# Arch Linux package for Veiron Control Center (Tauri).
#
# Build (from this directory, after Linux release artifacts exist):
#   makepkg -si
#
# Or build the AppImage on any Linux host and install without AUR:
#   bash scripts/release/build-linux-desktop.sh
#   chmod +x veiron-release/apps/linux/*.AppImage
#
# Status: Mainnet Candidate / Prototype Ă„â€šĂ‹ÂÄ‚ËĂ˘â‚¬ĹˇĂ‚Â¬Ä‚ËĂ˘â€šÂ¬ÄąÄ„ not public Mainnet.

pkgname=veiron-control-center
pkgver=1.0.0
pkgrel=1
pkgdesc="Veiron Mainnet Candidate Control Center (Tauri) â€” wallet, FiroPoW GPU miner, chain view"
arch=('x86_64')
url="https://veiron.network"
license=('LicenseRef-Proprietary')
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'libappindicator-gtk3'
  'openssl'
  'librsvg'
  'libsecret'
  'zenity'
)
optdepends=(
  'nvidia-utils: NVIDIA driver runtime for CUDA mining'
)
makedepends=(
  'rust'
  'cargo'
  'nodejs'
  'npm'
  'webkit2gtk-4.1'
  'base-devel'
  'curl'
  'wget'
  'file'
  'openssl'
  'appmenu-gtk-module'
  'libappindicator-gtk3'
  'librsvg'
)
options=('!lto') # Tauri/AppImage tooling can conflict with full LTO strip on Arch
source=()
sha256sums=()

# Expect monorepo checkout: packaging/arch is under veiron-desktop-tauri/
_repo_root="$(cd "${startdir}/../../.." && pwd)"

prepare() {
  cd "$_repo_root"
  # Nothing to download when building from a local monorepo tree.
  true
}

build() {
  cd "$_repo_root"
  export NO_STRIP=true
  bash scripts/release/build-linux-desktop.sh --bundles appimage,deb
}

package() {
  local out="$_repo_root/veiron-release/apps/linux"
  install -d "$pkgdir/usr/bin"
  install -d "$pkgdir/usr/share/applications"
  install -d "$pkgdir/usr/share/icons/hicolor/256x256/apps"
  install -d "$pkgdir/opt/veiron-control-center"

  # Prefer AppImage as portable payload under /opt, with a wrapper in PATH.
  local appimage
  appimage="$(find "$out" -maxdepth 1 -type f -name '*.AppImage' | head -1 || true)"
  if [[ -n "$appimage" ]]; then
    install -Dm755 "$appimage" "$pkgdir/opt/veiron-control-center/veiron-control-center.AppImage"
    cat > "$pkgdir/usr/bin/veiron-control-center" <<'WRAP'
#!/bin/sh
exec /opt/veiron-control-center/veiron-control-center.AppImage "$@"
WRAP
    chmod 755 "$pkgdir/usr/bin/veiron-control-center"
  else
    local bin="$_repo_root/veiron-desktop-tauri/src-tauri/target/release/veiron-desktop-tauri"
    if [[ -f "$bin" ]]; then
      install -Dm755 "$bin" "$pkgdir/usr/bin/veiron-control-center"
    else
      echo "No AppImage or release binary found" >&2
      return 1
    fi
  fi

  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/veiron-control-center.desktop" <<EOF
[Desktop Entry]
Name=Veiron Control Center
Comment=Veiron Mainnet Candidate wallet, miner and chain view
Exec=veiron-control-center
Icon=veiron-control-center
Terminal=false
Type=Application
Categories=Network;Finance;Utility;
Keywords=blockchain;veiron;mining;wallet;
EOF

  local icon=""
  for candidate in \
    "$_repo_root/veiron-desktop-tauri/src-tauri/icons/128x128.png" \
    "$_repo_root/veiron-desktop-tauri/src-tauri/icons/icon.png" \
    "$_repo_root/veiron-desktop-tauri/public/icon.png" \
    "$_repo_root/veiron-desktop-tauri/logo.png"
  do
    if [[ -f "$candidate" ]]; then
      icon="$candidate"
      break
    fi
  done
  if [[ -n "$icon" ]]; then
    install -Dm644 "$icon" "$pkgdir/usr/share/icons/hicolor/256x256/apps/veiron-control-center.png"
  fi
}
