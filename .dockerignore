# Veiron Docker Build Context — exclude everything unnecessary
# Context root: Veiron-Network-Main/ (set via compose.yaml build.context: ../..)

# Rust build artefacts
target/

# Version control
.git/
.gitignore
.gitattributes
.gitmodules

