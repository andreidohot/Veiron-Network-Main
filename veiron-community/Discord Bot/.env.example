DISCORD_TOKEN=replace_with_bot_token
DISCORD_CLIENT_ID=replace_with_application_client_id
DISCORD_GUILD_ID=replace_with_server_guild_id
LOG_LEVEL=info

# Discord Developer Portal:
# Enable Message Content Intent if you want automod to scan message text.

# Optional comma-separated Discord user IDs allowed to run setup.
# If empty, any server Administrator can run /setup-veiron.
SETUP_ALLOWED_USER_IDS=

# Optional admin panel. Keep disabled until the bot runs behind HTTPS or a private tunnel.
ADMIN_PANEL_ENABLED=false
ADMIN_PANEL_HOST=127.0.0.1
ADMIN_PANEL_PORT=8787
ADMIN_JWT_SECRET=replace_with_at_least_32_random_characters
ADMIN_JWT_TTL=15m
ADMIN_REFRESH_TOKEN_DAYS=14
ADMIN_TOTP_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
ADMIN_LOCKOUT_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15
ADMIN_DEFAULT_EMAIL=admin@veiron.local
ADMIN_DEFAULT_PASSWORD=replace_with_long_initial_password

# Optional web push notifications for the installable PWA dashboard.
# Generate keys with: npm run push:vapid
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@veiron.local

# Optional local JSON storage path.
BOT_DATA_DIR=./data

# Storage driver. Use json for local/demo storage or prisma for database-backed storage.
STORAGE_DRIVER=json
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./data/veiron-community.db
DATABASE_URL_LEDGER=file:./data/veiron-ledger.db

# Optional automated database backups.
# BACKUP_CRON uses UTC 5-field cron syntax. Default below means 03:00 UTC daily.
BACKUP_ENABLED=false
BACKUP_RUN_ON_STARTUP=false
BACKUP_CRON=0 3 * * *
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_JSON_DATA=true

# Optional S3-compatible upload target: AWS S3, Cloudflare R2, MinIO, Wasabi etc.
BACKUP_S3_ENABLED=false
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=veiron-community-bot
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_FORCE_PATH_STYLE=true

# Optional Veiron chain client mode and status endpoint.
# disabled: health reports chain client as disabled but OK.
# mock: /veiron-status returns clearly marked simulated metrics.
# rpc: /health checks VEIRON_CHAIN_RPC_URL and /veiron-status reads JSON metrics.
VEIRON_CHAIN_MODE=disabled
VEIRON_CHAIN_HEALTH_URL=
VEIRON_CHAIN_RPC_URL=
VEIRON_CHAIN_STATUS_URL=
VEIRON_CHAIN_STATUS_PATH=/status
VEIRON_CHAIN_REWARDS_URL=
VEIRON_CHAIN_REWARDS_PATH=/rewards/{address}
VEIRON_CHAIN_HEALTH_TIMEOUT_MS=3000
VEIRON_CHAIN_STATUS_TIMEOUT_MS=3000
VEIRON_CHAIN_REWARDS_TIMEOUT_MS=3000

# Optional Lavalink music module.
# In Docker Compose, use LAVALINK_HOST=lavalink.
MUSIC_ENABLED=false
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
# Optional multi-node override:
# LAVALINK_NODES=[{"name":"primary","url":"http://lavalink-a:2333","auth":"password-a"},{"name":"backup","url":"http://lavalink-b:2333","auth":"password-b"}]
MUSIC_DEFAULT_VOLUME=70
